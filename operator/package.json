{
  "name": "k3s-operator",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node22 --format=esm --outdir=dist --external:pg-native --external:@anthropic-ai/sdk --external:openai --external:@google/generative-ai --external:fastify --external:postgres --external:@kubernetes/client-node --external:yaml",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "fastify": "^5.3.3",
    "postgres": "^3.4.8",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
